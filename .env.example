# OpenClaw Environment Variables
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_MODE=local
# Allowed Origin domains, separated by commas
OPENCLAW_GATEWAY_ALLOWED_ORIGINS=http://localhost:18789,http://192.168.1.1:18789
# Allow insecure authentication (e.g., http), optional true/false
OPENCLAW_GATEWAY_ALLOW_INSECURE_AUTH=true
# Dangerous: disable device authentication (e.g., in Docker environment where device info cannot be obtained), optional true/false
OPENCLAW_GATEWAY_DANGEROUSLY_DISABLE_DEVICE_AUTH=false
# Gateway authentication mode, optional token
OPENCLAW_GATEWAY_AUTH_MODE=token
OPENCLAW_GATEWAY_TOKEN=123456

# OpenCode Environment Variables
OPENCODE_PORT=4096
OPENCODE_HOSTNAME=0.0.0.0


